# Copy this file to .env and fill in real values.
#   cp .env.example .env
# Documents every env var the backend reads. NO real secrets here.

# --- Provider selection (switch vendors here only) ---
EMBED_PROVIDER=gemini    # gemini | openai
LLM_PROVIDER=gemini      # gemini | openai
VECTOR_STORE=qdrant      # qdrant

# --- API keys ---
GEMINI_API_KEY=          # https://aistudio.google.com/apikey  (embeddings + generation)
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
OPENAI_API_KEY=          # only if EMBED_PROVIDER/LLM_PROVIDER = openai
COHERE_API_KEY=          # https://dashboard.cohere.com/api-keys  (Week 2 reranking)

# --- Qdrant (local Docker defaults) ---
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=finquery_chunks

# --- Models ---
EMBED_MODEL=text-embedding-004
EMBED_DIM=768
LLM_MODEL=gemini-2.0-flash

# --- Retrieval / chunking ---
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K=5

# --- Week 2: reranking (Cohere) ---
ENABLE_RERANK=false                  # true once COHERE_API_KEY is set
RERANK_PROVIDER=cohere               # cohere
RERANK_MODEL=rerank-english-v3.0
RETRIEVE_CANDIDATES=20               # over-fetch pool reranked down to TOP_K

# --- Week 2: hybrid retrieval (dense + BM25) ---
ENABLE_HYBRID=false                  # true once BM25 deps are installed
HYBRID_ALPHA=0.5                     # 1.0 = dense only, 0.0 = sparse only

# --- Week 3: agentic routing + web-search fallback ---
ENABLE_AGENT=false                   # route each question (docs | clarify | web) first
ENABLE_WEB_SEARCH=false              # opt-in fallback; needs the web-search dep
WEB_SEARCH_PROVIDER=duckduckgo       # duckduckgo (keyless) | tavily
WEB_SEARCH_MAX_RESULTS=5

# --- Week 3: RAGAS evaluation ---
EVAL_PROVIDER=ragas                  # ragas
EVAL_QUESTIONS_PATH=data/eval/questions.json
EVAL_RESULTS_PATH=data/eval/results.json
EVAL_BASELINE_PATH=data/eval/baseline.json
EVAL_SAMPLE_SIZE=2                   # 0 = all; keep SMALL on the free tier (20 gen/min)
EVAL_LLM_RPM=12                      # throttle RAGAS judge calls/min (< the 20/min cap)
EVAL_MAX_WORKERS=1                   # serialize RAGAS jobs so they don't burst the cap
EVAL_TIMEOUT=300                     # per-job timeout (s)
EVAL_CACHE_TTL_HOURS=48              # GET /evals serves the cached run this long (48h=2d, 24=1d, 1=1hr)

# --- CORS ---
FRONTEND_ORIGIN=http://localhost:5173
