# Keep the build context small and free of secrets.
# Without this, `build: .` ships venv/ (thousands of files), .git, the PDFs,
# and .env into the image build — slow, bloated, and a secret-leak risk.

# Secrets — never bake into an image (compose injects them at runtime via env_file)
.env
.env.*
!.env.example

# Python virtualenv + caches
venv/
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/

# Large data (PDFs are mounted at runtime, not baked in)
data/
qdrant_storage/

# Not needed at runtime
tests/
docs/
*.md
.git/
.gitignore
.cursor/
CLAUDE.md
.vscode/
.idea/
